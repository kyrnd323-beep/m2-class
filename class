        function submitProblem2(answer) {
            const feedback = document.getElementById('p2-feedback');
            feedback.classList.remove('hidden');

            document.querySelectorAll('.p2-opt-btn').forEach(btn => {
                btn.classList.remove('border-sky-500', 'bg-sky-50', 'border-rose-500', 'bg-rose-50');
            });

            // 답안 제출시에만 6x6 보드 전체에서 실제 정답 칸(초록)과 사용자 선택 오답 칸(빨강)을 입체적으로 교정/시각화
            for (let r = 1; r <= 6; r++) {
                for (let c = 1; c <= 6; c++) {
                    const cell = document.getElementById(`p-cell-${r}-${c}`);
                    const key = `${r}-${c}`;
                    const isSelected = p2SelectedGridSet.has(key);
                    const isCorrectAnswerCell = (r + c === 8);

                    if (isCorrectAnswerCell) {
                        // 실제 눈의 합이 8인 올바른 칸 -> 에메랄드 초록으로 하이라이트 피드백
                        cell.className = "p-cell w-10 h-10 border-r border-b border-emerald-300 bg-emerald-100 text-emerald-800 font-bold transition-all";
                    } else if (isSelected) {
                        // 사용자가 틀린 오답 칸을 잘못 선택한 경우 -> 부드러운 분홍색/빨간색으로 즉각 시각적 피드백 제공
                        cell.className = "p-cell w-10 h-10 border-r border-b border-rose-200 bg-rose-50 text-rose-500 font-bold transition-all";
                    } else {
                        // 미선택 영역 초기화
                        cell.className = "p-cell w-10 h-10 border-r border-b border-slate-200 font-black cursor-pointer hover:bg-sky-50 transition-colors";
                    }
                }
            }

            if (answer === '5/36') {
                feedback.innerHTML = "🎉 <strong>정답입니다!</strong><br>서로 다른 주사위 2개를 던질 때 일어날 수 있는 <strong class='text-indigo-600'>모든 경우의 수는 6 × 6 = 36가지</strong>입니다.<br>나오는 두 눈의 수의 합이 8이 되는 순서쌍은 보드에 초록색으로 드러난 <strong>5가지</strong>가 존재합니다.<br><span class='inline-block bg-white border px-2 py-0.5 rounded text-xs text-emerald-700 font-bold mt-1'>(2, 6), (3, 5), (4, 4), (5, 3), (6, 2)</span><br>따라서 두 눈의 수의 합이 8일 확률은 <strong>5/36</strong>이 됩니다.";
                feedback.className = "p-4 bg-emerald-50 text-emerald-800 border-2 border-emerald-200 rounded-2xl text-xs sm:text-sm leading-relaxed shadow-sm";
                showToast("2번 문제를 완벽히 통과했습니다! 🏆", true);
            } else {
                feedback.innerHTML = "💡 <strong>아쉬워요! 보드판의 색깔 지도를 살펴볼까요?</strong><br>주사위 두 개를 동시에 던지는 전체 경우의 수는 36가지입니다. 이 중 눈의 합이 정확히 8인 순서쌍들은 보드에 <span class='text-emerald-600 font-bold'>초록색으로 표시된 칸들</span>입니다. 이 칸들의 개수를 다시 세어 올바른 비율을 골라보세요.";
                feedback.className = "p-4 bg-rose-50 text-rose-800 border-2 border-rose-200 rounded-2xl text-xs sm:text-sm leading-relaxed shadow-sm";
                showToast("틀렸습니다. 정답 보정 카드를 관찰해 보세요!", false);
            }
        }

        // ==================== [2] Chart.js 리얼타임 데이터 시각화 ====================
        function initChart() {
            const canvas = document.getElementById('convergenceChart');
            const ctx = canvas.getContext('2d');
            
            if (convergenceChart !== null) {
                convergenceChart.destroy();
            }

            const targetLineVal = 1/6;
            const borderCol = '#0284c7'; // 핑구 오션 블루 컬러 테마 매칭
            const bgCol = 'rgba(2, 132, 199, 0.05)';

            convergenceChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: [0],
                    datasets: [
                        {
                            label: '누적 6의 눈 비율(상대도수)',
                            data: [0],
                            borderColor: borderCol,
                            backgroundColor: bgCol,
                            borderWidth: 2,
                            pointRadius: 1,
                            fill: true,
                            tension: 0.1
                        },
                        {
                            label: '이론상 목표선 (약 16.7%)',
                            data: [targetLineVal],
                            borderColor: '#ef4444', // 핑구 레드 하이라이트
                            borderWidth: 2,
                            borderDash: [6, 4],
                            pointRadius: 0,
                            fill: false
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            title: {
                                display: true,
                                text: '누적 주사위 던진 횟수',
                                font: { size: 10, weight: 'bold' }
                            },
                            grid: { display: false }
                        },
                        y: {
                            min: 0,
                            max: 0.6,
                            title: {
                                display: true,
                                text: '비율 값 (0% ~ 60%)',
                                font: { size: 10, weight: 'bold' }
                            },
                            ticks: {
                                callback: function(value) {
                                    return (value * 100).toFixed(0) + '%';
                                }
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: { font: { size: 11 } }
                        }
                    }
                }
            });
        }

        function updateChart() {
            if (!convergenceChart) return;

            const labels = diceDataHistory.map(d => d.trial);
            const dataPoints = diceDataHistory.map(d => d.ratio);
            const targetLine = Array(diceDataHistory.length).fill(1/6);

            if (labels.length === 0) {
                labels.push(0);
                dataPoints.push(0);
                targetLine.push(1/6);
            }

            convergenceChart.data.labels = labels;
            convergenceChart.data.datasets[0].data = dataPoints;
            convergenceChart.data.datasets[1].data = targetLine;

            convergenceChart.update('none'); 
        }

        // ==================== 초기 구동 및 로드 핸들링 ====================
        window.onload = function() {
            renderDiceFace(1);
            initChart();
            setSimCount(100);
            toggleDiceMode('manual');
        };
    </script>
</body>
</html>
