    <!-- JS Logic -->
    <script>
        // 전역 상태 변수들
        let activeTab = 'intro';
        
        // 주사위 실험 관련 데이터
        let diceSimCount = 100;
        let diceTotal = 0;
        let diceSixes = 0;
        let diceOthers = 0;
        const diceBias = 1/6; // 6의 눈이 나올 확률 = 1/6
        let diceDataHistory = []; // 수렴 그래프용 누적 기록

        // Chart.js 인스턴스
        let convergenceChart = null;

        // 실천 문제 관련 상태 변수들
        let isHighlightOddsActive = false;
        let p2SelectedGridSet = new Set(); // 사용자가 선택한 칸들을 담는 Set (비정답 실시간 피드백 무력화용)

        // 전역 알림 기능
        function showToast(message, isSuccess = true) {
            const toast = document.createElement('div');
            toast.className = `fixed bottom-5 right-5 ${isSuccess ? 'bg-emerald-600 border-emerald-700' : 'bg-rose-600 border-rose-700'} border text-white px-6 py-3.5 rounded-2xl shadow-2xl font-bold transition-all transform translate-y-0 z-[9999] text-sm flex items-center gap-2`;
            toast.innerHTML = `<span>✨</span> ${message}`;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 500);
            }, 3000);
        }

        // 탭 전환 시스템
        function switchTab(tabId) {
            activeTab = tabId;
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('border-sky-500', 'text-sky-600');
                btn.classList.add('border-transparent', 'text-slate-500');
            });
            document.getElementById(`tab-${tabId}`).classList.remove('border-transparent', 'text-slate-500');
            document.getElementById(`tab-${tabId}`).classList.add('border-sky-500', 'text-sky-600');

            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.add('hidden');
            });
            document.getElementById(`content-${tabId}`).classList.remove('hidden');

            if (tabId === 'experiment' && convergenceChart) {
                setTimeout(() => {
                    convergenceChart.resize();
                    convergenceChart.update();
                }, 50);
            }
        }

        // 미니 퀴즈 채점 시스템
        function checkQuizAnswer(quizId, isCorrect) {
            const feedback = document.getElementById(`${quizId}-feedback`);
            feedback.classList.remove('hidden');
            if (quizId === 'quiz1') {
                if (isCorrect) {
                    feedback.innerHTML = "🎉 <strong>정답입니다!</strong> 주사위를 단 10번만 던질 때는 6의 눈이 한 번도 나오지 않을 확률이 약 16.1%나 됩니다. 이처럼 실험 횟수가 적을 때는 예상했던 확률과 다른 돌발적인 결과가 충분히 벌어질 수 있어요.";
                    feedback.className = "mt-3 p-3 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-xl text-xs leading-relaxed font-semibold";
                } else {
                    feedback.innerHTML = "💡 <strong>한 번 더 생각해 보세요!</strong> 주사위의 6의 눈이 나올 확률이 1/6이라 하더라도, 각 시행은 매번 독립적이기 때문에 10번 모두 다른 눈(1~5)만 나올 가능성도 충분히 있습니다. 횟수가 적을 때는 우연적인 영향이 큽니다.";
                    feedback.className = "mt-3 p-3 bg-rose-50 text-rose-700 border border-rose-200 rounded-xl text-xs leading-relaxed font-semibold";
                }
            } else if (quizId === 'quiz2') {
                if (isCorrect) {
                    feedback.innerHTML = "🎉 <strong>정답입니다!</strong> 맞아요. 주사위를 던지는 횟수를 무수히 늘리면, 개별 던지기의 돌발적인 우연들이 상쇄되면서 점차 특정한 '수렴 기준선'으로 안착하게 됩니다. 이 약속된 정착지의 값이 과연 몇 퍼센트일지 실험 탭에서 눈으로 관찰해 보세요!";
                    feedback.className = "mt-3 p-3 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-xl text-xs leading-relaxed font-semibold";
                } else {
                    feedback.innerHTML = "💡 <strong>틀렸습니다!</strong> 개별 한 판은 완전히 우작위가 맞지만, 1만 번과 같이 거대한 횟수로 전체 비율을 모으면 신기하게도 요동을 멈추고 하나의 '질서 정연한 일정한 값'에 도달하게 됩니다. 직접 실험실에서 이 곡선을 목격해 보세요!";
                    feedback.className = "mt-3 p-3 bg-rose-50 text-rose-700 border border-rose-200 rounded-xl text-xs leading-relaxed font-semibold";
                }
            }
        }

        // ==================== [실험 및 입력 영역 토글 시스템] ====================
        function toggleDiceMode(mode) {
            const btnVirtual = document.getElementById('btn-mode-virtual');
            const btnManual = document.getElementById('btn-mode-manual');
            const secVirtual = document.getElementById('dice-section-virtual');
            const secManual = document.getElementById('dice-section-manual');

            if (mode === 'virtual') {
                btnVirtual.className = "flex-1 pb-2 text-sm font-black border-b-4 border-amber-500 text-amber-600 transition-all";
                btnManual.className = "flex-1 pb-2 text-sm font-black border-b-4 border-transparent text-slate-400 hover:text-slate-600 transition-all";
                secVirtual.classList.remove('hidden');
                secManual.classList.add('hidden');
            } else {
                btnVirtual.className = "flex-1 pb-2 text-sm font-black border-b-4 border-transparent text-slate-400 hover:text-slate-600 transition-all";
                btnManual.className = "flex-1 pb-2 text-sm font-black border-b-4 border-amber-500 text-amber-600 transition-all";
                secVirtual.classList.add('hidden');
                secManual.classList.remove('hidden');
            }
        }

        // ==================== [주사위 SVG 렌더링 시스템] ====================
        function renderDiceFace(num) {
            const el = document.getElementById('dice-face-svg');
            if (!el) return;
            
            const getDot = (cx, cy, color = '#1e293b') => `<circle cx="${cx}" cy="${cy}" r="7" fill="${color}" />`;
            let dots = '';

            if (num === 1) {
                dots = `<circle cx="50" cy="50" r="13" fill="#f43f5e" />`;
            } else if (num === 2) {
                dots = getDot(25, 25) + getDot(75, 75);
            } else if (num === 3) {
                dots = getDot(25, 25) + getDot(50, 50) + getDot(75, 75);
            } else if (num === 4) {
                dots = getDot(25, 25) + getDot(75, 25) + getDot(25, 75) + getDot(75, 75);
            } else if (num === 5) {
                dots = getDot(25, 25) + getDot(75, 25) + getDot(25, 75) + getDot(75, 75) + getDot(50, 50);
            } else if (num === 6) {
                const highlightColor = '#f59e0b';
                dots = getDot(25, 25, highlightColor) + getDot(25, 50, highlightColor) + getDot(25, 75, highlightColor) +
                       getDot(75, 25, highlightColor) + getDot(75, 50, highlightColor) + getDot(75, 75, highlightColor);
            }
            el.innerHTML = dots;
        }

        // 주사위 롤링 애니메이션 기능
        function animateDice(finalNum, callback) {
            const diceEl = document.getElementById('dice-element');
            let count = 0;
            const maxTicks = 10;
            
            const interval = setInterval(() => {
                const tempNum = Math.floor(Math.random() * 6) + 1;
                renderDiceFace(tempNum);
                
                const randomAngle = Math.random() * 40 - 20;
                const randomScale = 0.9 + Math.random() * 0.15;
                diceEl.style.transform = `rotate(${randomAngle}deg) scale(${randomScale})`;
                
                count++;
                if (count >= maxTicks) {
                    clearInterval(interval);
                    renderDiceFace(finalNum);
                    diceEl.style.transform = `rotate(0deg) scale(1)`;
                    if (callback) callback();
                }
            }, 60);
        }

        // ==================== [주사위 수동 및 스텝 컨트롤러] ====================
        function adjustManualDice10(diff) {
            const input = document.getElementById('manual-dice-sixes');
            let val = parseInt(input.value) || 0;
            val += diff;
            if (val < 0) val = 0;
            if (val > 10) val = 10;
            input.value = val;
            validateManualDice10(input);
        }

        // 가상 투척 선택기
        function setSimCount(cnt) {
            diceSimCount = cnt;
            document.getElementById('input-dice-custom').value = cnt;
            updateCountButtonStyles('count-btn', cnt);
        }

        function updateCountButtonStyles(className, selectedVal) {
            document.querySelectorAll(`.${className}`).forEach(btn => {
                const text = btn.innerText.replace('회 던지기', '');
                if (parseInt(text) === selectedVal) {
                    btn.className = `${className} py-3 text-sm font-bold rounded-lg bg-sky-600 text-white transition`;
                } else {
                    btn.className = `${className} py-3 text-sm font-bold rounded-lg bg-slate-100 hover:bg-slate-200 text-slate-700 transition`;
                }
            });
        }

        // [수동 1회 기록 추가]
        function recordManualDice(isSix) {
            diceTotal = 0;
            diceSixes = 0;
            diceOthers = 0;
            diceDataHistory = [];

            diceTotal++;
            let displayNum = 6;
            if (isSix) {
                diceSixes++;
            } else {
                diceOthers++;
                displayNum = Math.floor(Math.random() * 5) + 1;
            }
            
            diceDataHistory.push({
                trial: diceTotal,
                ratio: parseFloat((diceSixes / diceTotal).toFixed(4))
            });

            animateDice(displayNum, () => {
                document.getElementById('dice-text').innerText = `단발 기록! 결과: ${isSix ? '6의 눈 🎲' : '다른 눈(1~5)'}`;
                updateDiceUI();
                updateChart();
            });
            showToast(`실제 던진 결과 1회(${isSix ? '6의 눈' : '다른 눈'})가 등록되었습니다.`);
        }

        // [수동 10회 검증]
        function validateManualDice10(input) {
            let val = parseInt(input.value);
            if (isNaN(val) || val < 0) val = 0;
            if (val > 10) val = 10;
            input.value = val;
            document.getElementById('manual-dice-others').value = 10 - val;
        }

        // [수동 10회 일괄 등록]
        function submitManualDice10() {
            const sixesVal = parseInt(document.getElementById('manual-dice-sixes').value);
            const othersVal = parseInt(document.getElementById('manual-dice-others').value);

            if (isNaN(sixesVal) || (sixesVal + othersVal) !== 10) {
                showToast("값의 합이 정확히 10이어야 합니다.", false);
                return;
            }

            diceTotal = 0;
            diceSixes = 0;
            diceOthers = 0;
            diceDataHistory = [];

            let tempSixes = 0;
            let tempTotal = 0;

            let seq = [];
            for (let i = 0; i < sixesVal; i++) seq.push(true);
            for (let i = 0; i < othersVal; i++) seq.push(false);
            seq.sort(() => Math.random() - 0.5);

            seq.forEach(isSix => {
                tempTotal++;
                if (isSix) tempSixes++;
                diceDataHistory.push({
                    trial: tempTotal,
                    ratio: parseFloat((tempSixes / tempTotal).toFixed(4))
                });
            });

            diceTotal = 10;
            diceSixes = sixesVal;
            diceOthers = othersVal;

            const lastRollIsSix = seq[seq.length - 1];
            const finalFaceNum = lastRollIsSix ? 6 : (Math.floor(Math.random() * 5) + 1);

            animateDice(finalFaceNum, () => {
                document.getElementById('dice-text').innerText = `단발 10회 결과! (6의 눈: ${sixesVal}회, 다른 눈: ${othersVal}회)`;
                updateDiceUI();
                updateChart();
            });
            showToast(`실제 주사위 10회 던지기 실험 정보가 새롭게 기록되었습니다.`);
        }

        // [가상 대량 시뮬레이션 가동]
        function runDiceExperiment() {
            const customVal = parseInt(document.getElementById('input-dice-custom').value);
            if (isNaN(customVal) || customVal < 10) {
                showToast("던질 횟수를 최소 10회 이상으로 올바르게 입력해 주세요.", false);
                return;
            }
            diceSimCount = Math.min(customVal, 10000);

            document.getElementById('dice-text').innerText = "가상 주사위들을 초고속으로 돌리는 중...";
            
            const finalDummyFace = Math.floor(Math.random() * 6) + 1;
            animateDice(finalDummyFace, () => {
                executeDiceSimulation(diceSimCount);
            });
        }

        function executeDiceSimulation(count) {
            for (let i = 0; i < count; i++) {
                diceTotal++;
                const rolled = Math.floor(Math.random() * 6) + 1;
                if (rolled === 6) {
                    diceSixes++;
                } else {
                    diceOthers++;
                }

                if (diceTotal < 100 || diceTotal % Math.ceil(diceTotal / 100) === 0 || i === count - 1) {
                    diceDataHistory.push({
                        trial: diceTotal,
                        ratio: parseFloat((diceSixes / diceTotal).toFixed(4))
                    });
                }
            }

            document.getElementById('dice-text').innerText = `총 ${diceSimCount}회의 가상 주사위 투척 실험이 누적 반영되었습니다!`;
            updateDiceUI();
            updateChart();
        }

        // UI 갱신 데코레이터
        function updateDiceUI() {
            document.getElementById('dice-total').innerText = diceTotal;
            document.getElementById('dice-six-cnt').innerText = diceSixes;
            document.getElementById('dice-other-cnt').innerText = diceOthers;

            const ratio = diceTotal > 0 ? ((diceSixes / diceTotal) * 100).toFixed(2) : 0;
            document.getElementById('dice-six-ratio').innerText = `${ratio}%`;
            document.getElementById('dice-six-bar').style.width = `${ratio}%`;
            
            document.getElementById('dice-relative-freq-lbl').innerText = diceTotal > 0 ? `${ratio}%` : '0%';
        }

        // 초기화 루틴
        function resetDiceExperiment() {
            diceTotal = 0;
            diceSixes = 0;
            diceOthers = 0;
            diceDataHistory = [];
            
            renderDiceFace(1);
            document.getElementById('dice-text').innerText = "새로운 실험 환경이 준비되었습니다!";
            updateDiceUI();
            updateChart();
            showToast("실험 통계 및 차트 기록이 완벽히 초기화되었습니다.");
        }

        // ==================== [실천 문제 1번 (주머니 홀수 공) 로직] ====================
        function clickPracticeBall(num) {
            const ball = document.getElementById(`p-ball-${num}`);
