                feedback.className = "p-4 bg-emerald-50 text-emerald-800 border-2 border-emerald-200 rounded-2xl text-xs sm:text-sm leading-relaxed shadow-sm";
                showToast("1번 문제를 맞혔어요! 🐧", true);
            } else {
                feedback.innerHTML = "💡 <strong>다시 한번 생각해 보아요!</strong><br>1부터 9까지의 수 중에서 '홀수'의 개수가 총 몇 개인지 직접 세어보고, 주머니 속의 '전체 공 개수'에 대한 분수 비율을 구해 보세요.";
                feedback.className = "p-4 bg-rose-50 text-rose-800 border-2 border-rose-200 rounded-2xl text-xs sm:text-sm leading-relaxed shadow-sm";
                showToast("틀렸습니다. 다시 고민해 보세요!", false);
            }
        }

        // ==================== [실천 문제 2번 (격자 탐색) 로직 개편] ====================
        function clickPracticeGrid(r, c) {
            const key = `${r}-${c}`;
            const cell = document.getElementById(`p-cell-${r}-${c}`);

            // 힌트를 유발하는 자동 정답 판정을 제거하고, 자유로운 토글 마킹 기능만 수행
            if (p2SelectedGridSet.has(key)) {
                p2SelectedGridSet.delete(key);
                cell.className = "p-cell w-10 h-10 border-r border-b border-slate-200 font-black cursor-pointer hover:bg-sky-50 transition-colors";
